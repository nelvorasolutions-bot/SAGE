<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/speech"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bubble"
            android:paddingHorizontal="14dp"
            android:paddingVertical="9dp"
            android:text="Time to drink 💧"
            android:textColor="@color/deep"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"
            android:elevation="6dp"/>

        <ImageView
            android:id="@+id/buddy"
            android:layout_width="150dp"
            android:layout_height="220dp"
            android:scaleType="fitCenter"
            android:contentDescription="Water buddy"/>

        <LinearLayout
            android:id="@+id/panel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_bubble"
            android:padding="8dp"
            android:layout_marginTop="2dp"
            android:elevation="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnDrank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill"
                android:paddingHorizontal="16dp"
                android:paddingVertical="11dp"
                android:text="I drank 💧"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/btnSnooze"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="16dp"
                android:paddingVertical="11dp"
                android:layout_marginStart="8dp"
                android:text="Snooze"
                android:textColor="@color/deep"
                android:textStyle="bold"
                android:textSize="15sp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
